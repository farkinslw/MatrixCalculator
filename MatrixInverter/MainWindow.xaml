<Window x:Class="MatrixInverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Matrix Solver" Height="700" Width="1000" WindowStartupLocation="CenterScreen">

    <Window.Background>
        <ImageBrush ImageSource="https://images.alphacoders.com/507/thumb-1920-507637.png"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Background="Transparent" Margin="20,20,20,20" Grid.ColumnSpan="2">
            <DockPanel Margin="15">

                <Border DockPanel.Dock="Top" Background="#191970" Padding="15" CornerRadius="15" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Розмір:" Foreground="#FFB6C1" VerticalAlignment="Center" Margin="5,0,10,0" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Background="White" Margin="0,0,15,0">
                            <TextBox x:Name="txtSize" Width="40" Text="3" FontSize="16" TextAlignment="Center" VerticalContentAlignment="Center" IsReadOnly="True" BorderThickness="0"/>
                            <StackPanel Orientation="Vertical">
                                <RepeatButton Content="▲" Height="15" Width="20" FontSize="8" Click="BtnUp_Click" Background="#E6E6FA"/>
                                <RepeatButton Content="▼" Height="15" Width="20" FontSize="8" Click="BtnDown_Click" Background="#E6E6FA"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="Оновити" Click="BtnUpdate_Click" Background="#8A2BE2" Foreground="White" Width="90" Height="30" Margin="5" BorderThickness="0"/>
                        <Button Content="Random" Click="BtnRandom_Click" Background="#FF69B4" Foreground="White" Width="90" Height="30" Margin="5" BorderThickness="0"/>
                        <ComboBox x:Name="cmbMethod" Width="160" Margin="10,0" Height="30" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Гаус-Жордан" IsSelected="True"/>
                            <ComboBoxItem Content="Ньютон-Шульц"/>
                        </ComboBox>
                        <Button Content="РАХУВАТИ" Click="BtnCalc_Click" Background="#4B0082" Foreground="White" Width="120" Height="30" FontWeight="Bold" Margin="5" BorderThickness="0"/>
                    </StackPanel>
                </Border>

                <UniformGrid DockPanel.Dock="Bottom" Rows="1" Columns="3" Height="40" Margin="0,10,0,0">
                    <Border Background="#AAFFFFFF" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15,5">
                        <TextBlock x:Name="lblTime" Text="Час: -" Foreground="#191970" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#AAFFFFFF" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15,5">
                        <TextBlock x:Name="lblIters" Text="Ітер: -" Foreground="#191970" FontWeight="Bold"/>
                    </Border>
                    <Border Background="#AAFFFFFF" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15,5">
                        <TextBlock x:Name="lblComp" Text="Складність: O(n³)" Foreground="#191970" FontWeight="Bold"/>
                    </Border>
                </UniformGrid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10">
                        <Border Background="#AA4B0082" CornerRadius="5" HorizontalAlignment="Center" Padding="15,3" Margin="0,0,0,5">
                            <TextBlock Text="Матриця A" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <Border Background="#444B0082" BorderBrush="#FFB6C1" BorderThickness="2" CornerRadius="10">
                            <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <UniformGrid x:Name="GridIn" Margin="10"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10">
                        <Border Background="#AA800080" CornerRadius="5" HorizontalAlignment="Center" Padding="15,3" Margin="0,0,0,5">
                            <TextBlock Text="Результат A⁻¹" Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <Border Background="#44FF69B4" BorderBrush="#8A2BE2" BorderThickness="2" CornerRadius="10">
                            <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <UniformGrid x:Name="GridOut" Margin="10"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>